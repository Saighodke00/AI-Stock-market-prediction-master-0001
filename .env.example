# Core Redis
REDIS_URL="redis://localhost:6379/0"

# Alpaca Paper Trading Credentials (Required for Webhook Trades)
ALPACA_API_KEY="your_api_key_here"
ALPACA_SECRET_KEY="your_secret_key_here"
ALPACA_BASE_URL="https://paper-api.alpaca.markets"

# Local model checkpoint reference
MODEL_PATH="models/tft_model.ckpt"

# ── Alert System (alerts.py) ─────────────────────────────────────────────────

# Telegram Bot — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# SMTP Email — example uses Gmail SMTP SSL (port 465)
# For Gmail, generate an App Password at myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_app_password_here"

# Dashboard base URL used in email "View Full Analysis" button
DASHBOARD_URL="http://localhost:5173"

# ── Signal Reasoning Module (reasoning.py) ───────────────────────────────────

# Options: anthropic | openai
LLM_PROVIDER="anthropic"

# Tokens required for the selected provider
# Anthropic: get from console.anthropic.com
ANTHROPIC_API_KEY="your_anthropic_key_here"

# OpenAI: get from platform.openai.com
OPENAI_API_KEY="your_openai_key_here"
